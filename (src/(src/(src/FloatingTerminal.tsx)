import React, { useEffect, useState } from 'react';
import { eventBus } from './eventBus';

export const FloatingTerminal = () => {
  const [logs, setLogs] = useState<any[]>([]);

  useEffect(() => {
    const handleLog = (data: any) => {
      setLogs((prev) => [...prev, { ...data, id: Date.now() }]);
    };

    // Subscribe to events
    eventBus.on('terminal:log', handleLog);

    // Cleanup on unmount
    return () => eventBus.off('terminal:log', handleLog);
  }, []);

  return (
    // Your UI rendering code here
    <></>
  );
};
